{
  "_meta": {"name": "Archive Article Desk Edit Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.onecms.article",

  "type": "atex.onecms.article",
  "label": "Archive Article",
  "namePath": ["contentData", "title"],

  "aspects": {
    "contentData": {
      "type": "atex.onecms.article",
      "data": {
        "inputTemplate": "p.DamArticle"
      }
    },
    "atex.Metadata": {},
    "atex.dam.standard.Publevents": {}
  },

  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["securityParent", "status", "name", "headline", "body"]
      },
      {
        "label": "Resources",
        "fields": ["image"]
      },
      {
        "label": "TEMPLATE.TAB.METADATA",
        "fields": ["metadata"]
      },
      {
        "label": "Planning",
        "fields":["planning"]
      },
      {
        "label": "Publications",
        "fields": ["publevents"]
      }
    ]
  },

  "dataBindings": [
    {
      "name": "securityParent",
      "label": "TEMPLATE.FIELD.SECURITYPARENT",
      "widget": "damSecurityParent",
      "config": {
        "defaultSecurityParentId":"externalid/dam.assets.common.d"
      },
      "domainObjects": {
        "securityParentId": "p.InsertionInfo/securityParentId",
        "insertParentId": "p.InsertionInfo/insertParentId"
      }
    },
    {
      "name": "status",
      "label": "Status",
      "widget": "pContentStatus",
      "config": {
        "commentPlaceholder" : "Comment"
      },
      "domainObjects": {
        "contentStatus": "atex.WFContentStatus",
        "contentData": "contentData"
      }
    },
    {
      "name": "name",
      "label": "TEMPLATE.FIELD.NAME",
      "widget": "pTextInput",
      "config": {
      },
      "domainObjects": {
        "data": ["contentData", "name"]
      }
    },
    {
      "name": "headline",
      "label": "TEMPLATE.FIELD.HEADLINE",
      "widget": "pTextInput",
      "config": {
      },
      "domainObjects": {
        "data": ["contentData", "headline"]
      }
    },
    {
      "name": "body",
      "label": "Body",
      "widget": "pCKEditor",

      "config": {
        "height": "400"
      },

      "domainObjects": {
        "data": ["contentData", "body"]
      }
    },
    {
      "name": "image",
      "label": "Images & Resources",
      "widget": "pResourceArea",
      "config": {
        "mimeTypeMap": {
          "image/*": {"type": "atex.onecms.image", "inputTemplate": "p.DamImage"}
        }
      },
      "domainObjects": {
        "data": ["contentData", "resources"]
      }
    },
    {
      "name": "metadata",
      "label": "TEMPLATE.FIELD.METADATA",
      "widget": "pMetadata",

      "domainObjects": {
        "data": "atex.Metadata",
        "headline": "contentData/headline",
        "body": "contentData/body"
      },

      "config": {
        "annotation": true,
        "textsToAnnotate": ["headline","body"]
      }
    },
    {
      "name": "planning",
      "widget": "pDamTask",

      "config": {
        "editable":false,
        "types" : [{"label":"Article","value":"article"},{"label":"Image","value":"image"},{"label":"Images","value":"images"},{"label":"Video","value":"video"}],
        "ratios": [{"label":"4:3 standard","value":"4:3 standard"},{"label":"16:9 standard","value":"16:9 standard"},{"label":"21:9","value":"21:9"},{"label":"18:9 (2:1)","value":"18:9 (2:1)"}],
        "measurementUnit":"characters"
      },

      "domainObjects": {
        "data": "atex.Planning"
      }
    },
    {
      "name": "publevents",
      "label": "Publication Events",
      "widget": "pPublicationEvents",

      "config": {
        "fields": [
          { "name": "pubdate", "label": "Date", "format": "YYYY-MM-DD"},
          { "name": "publication", "label": "Publication", "lookupField": "publication"},
          { "name": "edition", "label": "Edition", "lookupField": "edition"},
          { "name": "pagelevel", "label": "Level", "lookupField": "pagelevel"},
          { "name": "page", "label": "Page"}
        ]
      },

      "domainObjects": {
        "data": "atex.dam.standard.Publevents"
      }
    }
  ]
}
