{
  "_meta": {"name": "Archive Image Desk Preview Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.onecms.image.dam.preview",

  "type": "atex.onecms.image",
  "label": "Archive Image Preview",
  "namePath": ["contentData", "title"],

  "aspects": {
    "contentData": {
      "type": "atex.onecms.image",
      "data": {
        "inputTemplate": "p.DamImage"
      }
    },
    "atex.Files": {},
    "atex.ImageEditInfo": {},
    "atex.Image": {},
    "atex.Metadata": {},
    "atex.ImageMetadata": {},
    "atex.dam.standard.Publevents": {}
  },

  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["image", "title", "caption", "description", "byline", "specialInstructions", "markForArchive", "urgency", "archiveComment"]
      },

      {
        "label": "TEMPLATE.TAB.METADATA",
        "fields": ["metadata"]
      },
      {
        "label": "Exif/Xmp/Iptc",
        "fields": ["exifMetadata"]
      },
      {
        "label": "Publications",
        "fields": ["publevents"]
      }
    ]
  },

  "dataBindings": [
    {
      "name": "image",
      "widget": "pImagePreview",

      "config": {
        "editable": false
      },

      "domainObjects": {
        "data": ["contentData"]
      }
    },
    {
      "name": "title",
      "label": "Title",
      "widget": "damFieldView",
      "domainObjects": {
        "data": ["contentData", "title"]
      }
    },
    {
      "name": "caption",
      "label": "Caption",
      "widget": "damFieldView",
      "domainObjects": {
        "data": ["contentData", "caption"]
      }
    },
    {
      "name": "description",
      "label": "TEMPLATE.FIELD.DESCRIPTION",
      "widget": "damFieldView",

      "domainObjects": {
        "data": ["contentData", "description"]
      }
    },
    {
      "name": "byline",
      "label": "By-line",
      "widget": "pExifMetadata",

      "domainObjects": {
        "data": "atex.ImageMetadata"
      },
      "config": {
        "editable": false,
        "full": false,
        "tags": {
          "IPTC": ["By-line"],
          "IPTC_types":["java.lang.String"]
        }
      }
    },
    {
      "name": "specialInstructions",
      "label": "Special Instructions",
      "widget": "pExifMetadata",

      "domainObjects": {
        "data": "atex.ImageMetadata"
      },
      "config": {
        "editable": false,
        "full": false,
        "tags": {
          "IPTC": ["SpecialInstructions"],
          "IPTC_types":["java.lang.String"]
        }
      }
    },
    {
      "name": "markForArchive",
      "label": "Mark for Archive",
      "widget": "pCheckbox",
      "config": {
        "editable": false,
        "defaultValue" : false
      },
      "domainObjects": {
        "data": "contentData/markForArchive"
      }
    },
    {
      "name": "urgency",
      "label": "Urgency",
      "widget": "pExifMetadata",

      "domainObjects": {
        "data": "atex.ImageMetadata"
      },
      "config": {
        "editable": false,
        "full": false,
        "tags": {
          "IPTC": ["Urgency"],
          "IPTC_types":["java.lang.Double"]
        }
      }
    },
    {
      "name": "archiveComment",
      "label": "Archive Comment",
      "widget": "damFieldView",

      "domainObjects": {
        "data": ["contentData", "archiveComment"]
      }
    },
    {
      "name": "metadata",
      "widget": "pMetadata",

      "domainObjects": {
        "data": "atex.Metadata"
      },

      "config": {
        "editable": false
      }
    },
    {
      "name": "exifMetadata",
      "label": "Exif/Xmp/Iptc",
      "widget": "pExifMetadata",

      "domainObjects": {
        "data": "atex.ImageMetadata"
      },
      "config": {
        "editable": false
      }
    },
    {
      "name": "publevents",
      "label": "Publication Events",
      "widget": "pPublicationEvents",

      "config": {
        "fields": [
          { "name": "pubdate", "label": "Date", "format": "yyyy-MM-dd"},
          { "name": "publication", "label": "Publication"},
          { "name": "edition", "label": "Edition"},
          { "name": "pagelevel", "label": "Level"},
          { "name": "page", "label": "Page"}
        ]
      },

      "domainObjects": {
        "data": "atex.dam.standard.Publevents"
      }
    }
  ]
}

