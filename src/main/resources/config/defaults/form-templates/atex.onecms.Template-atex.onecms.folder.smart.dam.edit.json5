{
  "_meta": {"name": "Smart Folder Desk Edit Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.dam.standard.Folder.smart",

  "type": "atex.dam.standard.Folder",
  "label": "Smart Folder",

  "aspects": {
    "atex.Metadata": {}
  },
  
  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["name"]
      },
  
      {
        "label": "Categorization and Filter Metadata",
        "fields": ["metadata"]
      }
    ]
  },
  
  "dataBindings": [
    {
      "name": "name",
      "label": "TEMPLATE.FIELD.NAME",
      "widget": "pTextInput",
      "config": {
        "placeholder": "The Folder Name"
      },
      "domainObjects": {
        "data": ["contentData", "name"]
      }
    },
    {
      "name": "metadata",
  	  "label": "TEMPLATE.FIELD.METADATA",
      "widget": "pMetadata",

      "domainObjects": {
        "data": "atex.Metadata"
      }
    }
  ]
}
