{
  "_meta": {"name": "Graphic Desk Preview Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.dam.standard.Graphic.dam.preview",

  "type": "atex.dam.standard.Graphic",
  "label": "Graphic",
  "namePath": ["contentData", "name"],

  "aspects": {
    "contentData": {
      "type": "atex.dam.standard.Graphic",
      "data": {
        "inputTemplate": "p.DamGraphic"
      }
    },
    "atex.Metadata": {},
    "p.InsertionInfo":{},
    "atex.Files": {}
  },

  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["imgView", "name", "headline", "description"]
      },
  
      {
        "label": "TEMPLATE.TAB.METADATA",
        "fields": ["metadata"]
      }
    ]
  },
  
  "dataBindings": [
    {
      "name": "imgView",
      "widget": "damImgView",
      "domainObjects": {
        "files": ["atex.Files"]
      }
    },
    {
      "name": "name",
      "label": "TEMPLATE.FIELD.NAME",
      "widget": "damFieldView",
      "domainObjects": {
        "data": ["contentData", "name"]
      }
    },
    {
      "name": "headline",
      "label": "TEMPLATE.FIELD.HEADLINE",
      "widget": "damFieldView",
      "domainObjects": {
        "data": ["contentData", "headline"]
      }
    },
    {
      "name": "description",
      "label": "TEMPLATE.FIELD.DESCRIPTION",
      "widget": "damFieldView",
      "domainObjects": {
        "data": ["contentData", "description"]
      }
    },
    {
      "name": "metadata",
      "widget": "pMetadata",

      "domainObjects": {
        "data": "atex.Metadata"
      },

      "config": {
        "editable": false
      }
    }
  ]
}
