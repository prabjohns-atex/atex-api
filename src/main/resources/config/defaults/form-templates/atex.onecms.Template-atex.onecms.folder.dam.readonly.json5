{
  "_meta": {"name": "Folder Desk Read Only Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.dam.standard.Folder.readonly",

  "type": "atex.dam.standard.Folder",
  "label": "Folder",

  "aspects": {
    "atex.Metadata": {}
  },

  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["securityParent", "name"]
      },

      {
        "label": "Categorization Metadata",
        "fields": ["metadata"]
      }
    ]
  },
  
  "dataBindings": [
    {
      "name": "securityParent",
      "label": "TEMPLATE.FIELD.SECURITYPARENT",
      "widget": "damSecurityParent",
      "config": {
        "editable" : false
      },
      "domainObjects": {
        "securityParentId": "p.InsertionInfo/securityParentId",
        "insertParentId": "p.InsertionInfo/insertParentId"
      }
    },
    {
      "name": "name",
      "label": "TEMPLATE.FIELD.NAME",
      "widget": "pTextInput",
      "config": {
        "placeholder": "The Folder Name"
      },
      "domainObjects": {
        "data": ["contentData", "name"]
      }
    },
    {
      "name": "metadata",
  	  "label": "TEMPLATE.FIELD.METADATA",
      "widget": "pMetadata",

      "domainObjects": {
        "data": "atex.Metadata"
      }
    }
  ]
}
