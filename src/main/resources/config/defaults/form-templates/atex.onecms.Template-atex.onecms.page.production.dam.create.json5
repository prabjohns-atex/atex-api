{
  "_meta": {"name": "Production Page Desk Create Template", "group": "Templates", "format": "atex.onecms.Template.it"},
  "id": "atex.dam.standard.Page.production.dam.create",

  "type": "atex.dam.standard.Page",
  "label": "Page",
  "namePath": ["contentData", "name"],

  "aspects": {
    "contentData": {
      "type": "atex.dam.standard.Page",
      "data": {
        "inputTemplate": "p.OnePage"
      }
    },
    "atex.Files": {}
  },

  "layout": {
    "views": [
      {
        "label": "TEMPLATE.TAB.GENERAL",
        "fields": ["shapesView"]
      }
    ]
  },
  
  "dataBindings": [
    {
      "name": "shapesView",
      "widget": "shapesView",
      "domainObjects": {
        "data": ["contentData", "name"],
        "width": ["contentData", "width"],
        "height": ["contentData", "height"]
      },
      "config": {
        "module": "createPage",
        "shapeMode": 6
      }
    }
  ]
}
